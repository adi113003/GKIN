{
  "manifest_version": 3,
  "name": "GKIN Truth Navigator",
  "version": "1.0",
  "description": "Analyze any news article for manipulation, misinformation, and hidden narratives.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GKIN Truth Navigator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
