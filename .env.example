# GKIN environment — copy to .env and fill in. .env is gitignored; never commit real keys.
# What works without the OPTIONAL keys: full analysis, grounded /verify-claims, and
# /timeline all run on GROQ + keyless Wikipedia/DuckDuckGo search. Optional keys only
# add Google login, extra search backends, and the competitor benchmark.

# ─────────────── REQUIRED ───────────────
# LLM backend — without this, /analyze, /verify-claims, /timeline, /chat return 500.
GROQ_API_KEY=your_groq_api_key
# MongoDB (Atlas free tier is fine) — needed for register/login and saved investigations.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/gkin?retryWrites=true&w=majority&appName=Cluster0
# JWT signing secret for auth tokens.
SECRET_KEY=your_secret_key

# ─────────────── OPTIONAL ───────────────
# Google OAuth login (username/password auth works without these):
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://gkin.app/auth/google/callback

# Extra search backends for the agentic loop (keyless Wikipedia + DuckDuckGo are the default):
# BRAVE_API_KEY=your_brave_search_key
# GOOGLE_API_KEY=your_google_programmable_search_key

# Deployment / ops:
# GKIN_VERSION=1.0.0
# GKIN_ENV=production

# Automated competitor benchmark (benchmark/run_competitor_benchmark.py) — all optional;
# missing providers are skipped gracefully, no scores are fabricated:
# GKIN_BASE_URL=http://localhost:8000
# GKIN_USERNAME=benchmark
# GKIN_PASSWORD=benchmarkpass123
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
# PERPLEXITY_API_KEY=your_perplexity_api_key
# PERPLEXITY_MODEL=sonar
# JUDGE_MODEL=gpt-4o-mini   # used by --mode judge (LLM-as-judge)
