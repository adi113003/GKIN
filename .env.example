MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/gkin?retryWrites=true&w=majority&appName=Cluster0
GROQ_API_KEY=your_groq_api_key
SECRET_KEY=your_secret_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://gkin.app/auth/google/callback

# ── Optional: search backends for the agentic verification loop ──
# BRAVE_API_KEY=your_brave_search_key
# GOOGLE_API_KEY=your_google_programmable_search_key

# ── Optional: automated competitor benchmark (benchmark/run_competitor_benchmark.py) ──
# All optional. Missing providers are skipped gracefully.
# GKIN_BASE_URL=http://localhost:8000
# GKIN_USERNAME=benchmark
# GKIN_PASSWORD=benchmarkpass123
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
# PERPLEXITY_API_KEY=your_perplexity_api_key
# PERPLEXITY_MODEL=sonar
# JUDGE_MODEL=gpt-4o-mini   # used by --mode judge (LLM-as-judge)
